# Token du bot Discord — à générer dans Developer Portal → Bot → Reset Token
DISCORD_BOT_TOKEN=

# ID du salon où poster le message — activer le mode développeur dans Discord,
# clic droit sur le salon → "Copier l'ID du salon"
DISCORD_WELCOME_CHANNEL_ID=

# URL publique du site. En dev local : http://localhost:3000
# En prod : ton domaine (Vercel, custom, etc.)
SITE_URL=http://localhost:3000

# Optionnel : ID d'un message déjà posté si tu veux l'éditer au lieu d'en poster un nouveau
DISCORD_WELCOME_MESSAGE_ID=
